# Live Video Delay Replay System — web login (all pages and HLS)
#
# Copy for each unit during construction:
#   cp web.env.example web-UNIT123456.env
# Install on the Pi as:
#   /etc/sportassist/web.env
#
# Do not commit real passwords to git — keep site copies offline.

# Username and password for all web access (replay, settings, HLS, presets).
SETTINGS_USERNAME='admin'
SETTINGS_PASSWORD='ChangeMe-Before-Deploy-Settings'

# Additional password required to open /settings (after web login).
SETTINGS_VIEW_PASSWORD='ChangeMe-Settings-View'

# Flask session signing key — unique per unit (openssl rand -hex 32).
FLASK_SECRET_KEY='replace-with-random-hex-at-construction'

# Idle session timeout in seconds (default 28800 = 8 hours).
WEB_SESSION_TIMEOUT=28800
