# Live Video Delay Replay System — appliance identity and Wi‑Fi AP
#
# Copy this file for each unit during construction:
#   cp appliance.env.example appliance-UNIT123456.env
# Edit APPLIANCE_SERIAL and AP_PSK, then install to the Pi as:
#   /etc/sportassist/appliance.env
#
# Build scripts merge appliance.env into wifi-ap.env on the device.
# Web login: see config/web.env.example → /etc/sportassist/web.env
# Do not commit real passwords to git — keep site copies offline.

# Unique serial for this unit (printed on label / recorded in install log).
# Used in Wi‑Fi SSID: sport-assist-{APPLIANCE_SERIAL}
APPLIANCE_SERIAL=UNIT123456

# WPA2 passphrase for the Wi‑Fi access point (min 8 characters).
AP_PSK='ChangeMe-Before-Deploy-K9mAs5ist'

# ISO 3166-1 alpha-2 country code for Wi‑Fi regulatory domain.
AP_COUNTRY_CODE=GB

# Optional: override default AP channel (2.4 GHz). Leave unset to use 6.
# AP_CHANNEL=6
