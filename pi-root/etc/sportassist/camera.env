# Replay appliance camera connection (Pi only)
# Updated via /settings — ONVIF interrogation, auto-configured stream profiles.

CAMERA_HOSTNAME=
CAMERA_IP=
# ONVIF serial / model identifier — used to find camera after IP change
CAMERA_DEVICE_ID=
# Human-readable model name from camera (e.g. IPC3638SB-S-AL2 (SN123))
CAMERA_REPORTED_NAME=
# Set to 1 after Assign camera (sportassist user + generated password)
CAMERA_ASSIGNED=0
CAMERA_RTSP_PORT=554
CAMERA_ONVIF_PORT=80
CAMERA_RTSP_TRANSPORT=tcp
CAMERA_USERNAME=
CAMERA_PASSWORD=

# Main stream (HDMI) — set by ldrs-configure-camera-streams.sh via ONVIF
CAMERA_RTSP_PATH=
INGEST_WIDTH=
INGEST_HEIGHT=
INGEST_FPS=
INGEST_CODEC=ultra265
INGEST_BITRATE=
INGEST_GOP=25
CAMERA_STREAM_LABEL=
INGEST_FALLBACK_STEP=

# Sub stream (Wi‑Fi 1080p remux) — when main resolution > 1080p
CAMERA_RTSP_PATH_SUB=
INGEST_SUB_WIDTH=1920
INGEST_SUB_HEIGHT=1080
INGEST_SUB_FPS=25
INGEST_SUB_CODEC=h264
INGEST_SUB_BITRATE=5000000
INGEST_SUB_GOP=25
