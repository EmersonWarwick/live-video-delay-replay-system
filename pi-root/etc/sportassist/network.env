# Sport Assist Ethernet — camera link (not Wi‑Fi AP)
#
# ETH_CAMERA_DHCP controls whether the Pi runs a DHCP server on eth0
# for the IP camera when it is connected directly to the Pi.
#
# 1 = Camera connected directly to Raspberry Pi Ethernet (Pi is DHCP server)
# 0 = Camera on customer Ethernet network (external DHCP; Pi discovers camera)
#
# Changed from the /settings page via ldrs-set-eth-camera-dhcp.sh

ETH_CAMERA_DHCP=1

PI_INTERFACE=eth0
PI_STATIC_IP=192.168.10.1
PI_NETMASK=255.255.255.0
ETH_DHCP_RANGE_START=192.168.10.100
ETH_DHCP_RANGE_END=192.168.10.150
ETH_DHCP_LEASE_TIME=24h
