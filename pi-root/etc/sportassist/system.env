# Live Video Delay Replay System — runtime defaults

# Camera / capture (4K ingest)
CAPTURE_WIDTH=3840
CAPTURE_HEIGHT=2160
CAPTURE_FPS=25

# Tier A — 4K HDMI buffer
HDMI_BUFFER_WIDTH=3840
HDMI_BUFFER_HEIGHT=2160
HDMI_BUFFER_BITRATE=12000000

# Tier B — 1080p Wi-Fi HLS (Android / tablets)
WIFI_HLS_WIDTH=1920
WIFI_HLS_HEIGHT=1080
WIFI_HLS_BITRATE=5000000

# Shared timing
# LIVE_DELAY_SECONDS = wall-clock seconds from live to HDMI and tablet replay edge.
# PLAYBACK_OFFSET = LIVE_DELAY - PIPELINE_LATENCY - HDMI_PLAYBACK_BIAS (seconds behind HLS edge).
# Tune PIPELINE_LATENCY_SECONDS to match real ingest lag (often ~3s, not 7s).
PIPELINE_LATENCY_SECONDS=3
HDMI_PLAYBACK_BIAS_SECONDS=0
HDMI_VLC_CACHING_MS=200
LIVE_DELAY_SECONDS=14
BUFFER_DURATION_SECONDS=1200
HLS_SEGMENT_DURATION=1
HDMI_ENABLED=1
# Remote shell (sshd) on eth0 and wlan0 — toggled from /settings
SSH_ENABLED=1
# HDMI coach monitor: delayed (~LIVE_DELAY_SECONDS) or live (minimal HLS edge latency)
HDMI_OUTPUT_MODE=delayed
HDMI_LIVE_CACHING_MS=100
# Idle splash logo + title rotation on HDMI (degrees: -90, 0, 90)
IDLE_SPLASH_ROTATION=0
# HDMI monitor output: auto = EDID preferred; force_4k = 3840x2160@60 via cmdline video=
HDMI_RESOLUTION_MODE=auto
